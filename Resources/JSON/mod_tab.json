{
    "type": "QWidget",
    "layout": {
        "type": "QVBoxLayout",
        "children": [
            {
                "type": "QLabel",
                "text": "Edelweiss.Modding.MapHierarchyPresets",
                "id": "heading"
            },
            {
                "type": "QComboBox",
                "tooltip": "Edelweiss.Modding.SelectorDescription",
                "modifiable": true,
                "canEditDefaults": false,
                "defaults": ["Default", "CollabUtils2"],
                "bind": {
                    "options": "Edelweiss:ModdingTab.MapPresetNames",
                    "selected": "Edelweiss:ModdingTab.CurrentPresetName"
                },
                "add": null,
                "change": {
                    "method": "Edelweiss:ModdingInterop.ChangeMapPreset",
                    "args": ["@text"]
                },
                "remove": {
                    "method": "Edelweiss:ModdingInterop.RemoveMapPreset",
                    "args": ["@0"]
                },
                "edit": {
                    "method": "Edelweiss:ModdingInterop.RenameMapPreset",
                    "args": ["@0", "@1"]
                }
            },
            {
                "type": "Form",
                "model": "Edelweiss:ModdingTab",
                "fields": ["CurrentPreset"],
                "fieldInfo": {
                    "CurrentPreset": {
                        "type": "formList",
                        "label": false,
                        "form": {
                            "root": "Edelweiss.Modding.MapHierarchy",
                            "fields": ["Name", "Directory"],
                            "fieldLayout": [
                                ["Name"],
                                ["Directory"]
                            ]
                        }
                    }
                }
            },
            {
                "isSpacer": true
            }
        ]
    }
}